cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]

# Virtual env
.venv/

# Streamlit
.streamlit/

# OS / Editor
.DS_Store
.vscode/
.idea/

# Keep samples, ignore other CSV exports by default
*.csv
!samples/*.csv
EOF
# Logs
*.log

# Logs
*.log
launchd.out.log
launchd.err.log
streamlit.log

# Local logs
*.log
launchd.out.log
launchd.err.log
streamlit.log

# Virtual env
.venv/

# Bundles
*.bundle
